{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "types": ["vitest/globals"]
  },
  "include": [
    "worker-configuration.d.ts",
    "src/**/*.ts",
    "tests/**/*.ts"
  ]
}

